<?xml version="1.0" encoding="utf-8"?>
<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:id="@+id/player1Lives"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Player 1: 3 Lives"
        android:textSize="18sp"
        android:layout_alignParentTop="true"
        android:layout_alignParentStart="true"
        android:layout_margin="16dp" />

    <TextView
        android:id="@+id/player2Lives"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Player 2: 3 Lives"
        android:textSize="18sp"
        android:layout_below="@id/player1Lives"
        android:layout_alignParentStart="true"
        android:layout_margin="16dp" />

    <TextView
        android:id="@+id/player3Lives"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Player 3: 3 Lives"
        android:textSize="18sp"
        android:layout_below="@id/player2Lives"
        android:layout_alignParentStart="true"
        android:layout_margin="16dp" />

</RelativeLayout>