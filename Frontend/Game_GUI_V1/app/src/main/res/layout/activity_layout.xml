<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- activity_level.xml -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/grass_and_sky"
        tools:layout_editor_absoluteX="-16dp"
        tools:layout_editor_absoluteY="-43dp">
        <!-- A background -->

        <!-- Ground Block (across bottom) -->

        <!-- Platform Block 1 -->

        <ImageView
            android:id="@+id/groundBlock"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/ground_block"
            tools:layout_editor_absoluteX="0dp"
            tools:layout_editor_absoluteY="568dp" />

        <!-- Platform Block 2, positioned higher for jumping -->

        <!-- Higher Block that can only be reached by jumping from another block -->

        <ImageView
            android:id="@+id/platformBlock1"
            app:layout_constraintBottom_toTopOf="@+id/groundBlock"
            app:layout_constraintHorizontal_bias="0.2"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_margin="8dp"
            android:background="@drawable/cloud_block"
            tools:layout_editor_absoluteX="274dp"
            tools:layout_editor_absoluteY="478dp" />

        <ImageView
            android:id="@+id/platformBlock2"
            app:layout_constraintBottom_toTopOf="@+id/platformBlock1"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintStart_toEndOf="@+id/platformBlock1"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_margin="8dp"
            android:background="@drawable/cloud_block"
            tools:layout_editor_absoluteX="83dp"
            tools:layout_editor_absoluteY="478dp" />

        <ImageView
            android:id="@+id/highBlock"
            app:layout_constraintBottom_toTopOf="@+id/platformBlock2"
            app:layout_constraintHorizontal_bias="0.7"
            app:layout_constraintStart_toEndOf="@+id/platformBlock2"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_margin="8dp"
            android:background="@drawable/cloud_block"
            tools:layout_editor_absoluteX="180dp"
            tools:layout_editor_absoluteY="478dp" />


    </androidx.constraintlayout.widget.ConstraintLayout>
