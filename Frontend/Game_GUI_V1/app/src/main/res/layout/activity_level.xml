<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/grass_and_sky"
    tools:context=".LevelActivity">

    <!-- Countdown Timer TextView -->
    <TextView
        android:id="@+id/countdownTimer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Time Remaining:"
        android:textSize="24sp"
        android:textColor="@android:color/black"
        android:layout_marginTop="16dp"
        android:layout_marginStart="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Ground Block (across bottom) -->
    <ImageView
        android:id="@+id/groundBlock"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="@drawable/ground_block"
        android:tag="obstacle"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Platform Blocks -->
    <ImageView
        android:id="@+id/platformBlock1"
        android:layout_width="60dp"
        android:layout_height="50dp"
        android:layout_marginStart="160dp"
        android:layout_marginTop="312dp"
        android:background="@drawable/cloud_block"
        android:tag="obstacle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/platformBlock2"
        android:layout_width="85dp"
        android:layout_height="50dp"
        android:layout_marginTop="292dp"
        android:layout_marginEnd="156dp"
        android:background="@drawable/cloud_block"
        android:tag="obstacle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/platformBlock3"
        android:layout_width="75dp"
        android:layout_height="50dp"
        android:background="@drawable/cloud_block"
        android:tag="obstacle"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.443"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.624" />

    <ImageView
        android:id="@+id/platformBlock4"
        android:layout_width="80dp"
        android:layout_height="50dp"
        android:layout_marginStart="104dp"
        android:layout_marginBottom="204dp"
        android:background="@drawable/cloud_block"
        android:tag="obstacle"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageView
        android:id="@+id/platformBlock5"
        android:layout_width="100dp"
        android:layout_height="50dp"
        android:layout_marginEnd="260dp"
        android:layout_marginBottom="216dp"
        android:background="@drawable/cloud_block"
        android:tag="obstacle"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Player Characters -->
    <ImageView
        android:id="@+id/player1"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginStart="56dp"
        android:layout_marginBottom="156dp"
        android:src="@drawable/kong_1"
        app:layout_constraintBottom_toTopOf="@+id/groundBlock"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageView
        android:id="@+id/player2"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginStart="256dp"
        android:layout_marginBottom="156dp"
        android:src="@drawable/kong_1"
        app:layout_constraintBottom_toTopOf="@+id/groundBlock"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageView
        android:id="@+id/player3"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginEnd="256dp"
        android:layout_marginTop="156dp"
        android:src="@drawable/kong_1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/player4"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginEnd="56dp"
        android:layout_marginTop="256dp"
        android:src="@drawable/kong_1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Position Debugger -->
    <TextView
        android:id="@+id/positionDebugger"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="288dp"
        android:layout_marginBottom="680dp"
        android:text="Player Position: x=0.00, y=0.00"
        android:textColor="@android:color/black"
        android:textSize="16sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>


